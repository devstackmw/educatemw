rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, phoneNumber, displayName, photoURL, isPremium, createdAt
    //
    // Collection: userStats
    // Fields: uid, points, streak, lastActiveDate
    //
    // Collection: syllabusProgress
    // Fields: uid, subject, topic, completed
    //
    // Collection: papers, quizzes, notes, flashcardSets
    // Fields: subject, topic, ..., isPremiumOnly
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "devstackmw@gmail.com" ||
         request.auth.token.email == "mscepreparation@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isPremium() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isPremium == true;
    }

    // ===============================================================
    // Validation Functions
    // ===============================================================

    function isValidUser(data) {
      return data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             data.isPremium is bool &&
             data.createdAt is string &&
             data.referralCode is string &&
             data.aiPoints is number &&
             (!('paymentStatus' in data) || data.paymentStatus in ['pending', 'approved', 'failed']);
    }

    function isValidUserStats(data) {
      return data.keys().hasAll(['uid', 'displayName', 'points', 'streak', 'lastActiveDate', 'isPremium']) &&
             data.uid == request.auth.uid &&
             data.points is number &&
             data.streak is number &&
             data.lastActiveDate is string &&
             data.isPremium is bool &&
             (!('dailyChallenge' in data) || (data.dailyChallenge.completed is bool && data.dailyChallenge.date is string));
    }

    function isValidPost(data) {
      return data.keys().hasAll(['uid', 'authorName', 'content', 'likes', 'commentsCount', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 1000 &&
             data.likes is number && data.likes >= 0 &&
             data.commentsCount is number && data.commentsCount >= 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles (Private)
    match /users/{userId} {
      // Only the owner can read/write their own profile, but admins can manage all
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['aiPoints']) &&
                     request.resource.data.aiPoints == resource.data.aiPoints + 2);
    }

    // Referrals
    match /referrals/{referralId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.referredUid == request.auth.uid;
    }

    // Public Profiles (For Leaderboard/Premium Students)
    match /publicProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Community Posts
    match /posts/{postId} {
      // All authenticated users can read posts
      allow read: if isAuthenticated();
      // Only premium users can create posts
      allow create: if isPremium() && isValidPost(request.resource.data);
      // Only the owner or an admin can delete a post
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.uid || isAdmin());
      // Users can update likes (only increment/decrement)
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes']) &&
                    math.abs(request.resource.data.likes - resource.data.likes) == 1;
    }

    // User Stats & Progress
    match /userStats/{userId} {
      // Allow all authenticated users to read stats for the leaderboard
      allow read: if isAuthenticated();
      allow write: if (isOwner(userId) && isValidUserStats(request.resource.data)) ||
                    (isAuthenticated() && 
                     request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']) &&
                     request.resource.data.points == resource.data.points + 10);
    }

    match /syllabusProgress/{progressId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow write: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
    }

    // Educational Content (Read-only for all authenticated students)
    // This ensures no "Missing or insufficient permissions" errors when listing content
    
    match /papers/{paperId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isPremium() || isAdmin();
      allow update, delete: if isAdmin();
      
      match /questions/{questionId} {
        allow read: if isAuthenticated();
        allow create: if isPremium() || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /videos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /flashcardSets/{setId} {
      allow read: if isAuthenticated();
      allow create: if isPremium() || isAdmin();
      allow update, delete: if isAdmin();
      
      match /cards/{cardId} {
        allow read: if isAuthenticated();
        allow create: if isPremium() || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    match /dailyContent/{contentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount']) &&
                    request.resource.data.viewCount == resource.data.viewCount + 1;
      allow write: if isAdmin();
    }

    match /announcements/{annId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /examDates/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAdmin();
      allow write: if false; // Only via admin SDK (webhook)
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // Default deny for everything else (including write access to content)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
