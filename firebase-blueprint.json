{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Educate MW app.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "nickname": {
          "type": "string",
          "description": "The user's nickname."
        },
        "realName": {
          "type": "string",
          "description": "The user's real name."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has an active premium subscription."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The ISO 8601 timestamp when the user was created."
        },
        "referralCode": {
          "type": "string",
          "description": "Unique referral code for the user."
        },
        "aiPoints": {
          "type": "number",
          "description": "Number of AI questions available for free users."
        }
      },
      "required": ["uid", "displayName", "isPremium", "createdAt", "referralCode", "aiPoints"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Tracks a referral from one user to another.",
      "type": "object",
      "properties": {
        "referrerUid": { "type": "string" },
        "referredUid": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerUid", "referredUid", "createdAt"]
    },
    "Paper": {
      "title": "Past Paper",
      "description": "A past examination paper.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "year": { "type": "string" },
        "level": { "type": "string" },
        "size": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "isPremiumOnly": { "type": "boolean" }
      },
      "required": ["subject", "year", "level", "size", "downloadUrl", "isPremiumOnly"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz challenge.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "form": { "type": "string", "description": "The class level (e.g., Form 1)" },
        "questionsCount": { "type": "number" },
        "timeLimit": { "type": "string" },
        "color": { "type": "string" },
        "isPremiumOnly": { "type": "boolean" },
        "isAIGenerated": { "type": "boolean" }
      },
      "required": ["subject", "topic", "questionsCount", "timeLimit", "color", "isPremiumOnly"]
    },
    "Note": {
      "title": "Study Note",
      "description": "A study note for a specific subject.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Optional URL to an image hosted on Cloudinary/Drive" },
        "videoUrl": { "type": "string", "description": "Optional URL to a YouTube video" },
        "isPremiumOnly": { "type": "boolean" }
      },
      "required": ["subject", "topic", "content", "isPremiumOnly"]
    },
    "Question": {
      "title": "Quiz Question",
      "description": "A single question within a quiz.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswerIndex": { "type": "number" }
      },
      "required": ["text", "options", "correctAnswerIndex"]
    },
    "UserStats": {
      "title": "User Statistics",
      "description": "User points, streaks, and activity.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "points": { "type": "number" },
        "streak": { "type": "number" },
        "lastActiveDate": { "type": "string", "format": "date" },
        "earnedBadges": { "type": "array", "items": { "type": "string" }, "description": "List of badge IDs earned by the user." }
      },
      "required": ["uid", "displayName", "points", "streak", "lastActiveDate"]
    },
    "Badge": {
      "title": "Badge",
      "description": "An achievement badge.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "criteria": { "type": "string" }
      },
      "required": ["id", "name", "description", "icon"]
    },
    "SyllabusProgress": {
      "title": "Syllabus Progress",
      "description": "Progress tracking for subjects and topics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "completed": { "type": "boolean" }
      },
      "required": ["uid", "subject", "topic", "completed"]
    },
    "FlashcardSet": {
      "title": "Flashcard Set",
      "description": "A collection of flashcards for a specific topic.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "cardsCount": { "type": "number" },
        "color": { "type": "string" },
        "isPremiumOnly": { "type": "boolean" }
      },
      "required": ["subject", "topic", "cardsCount", "color", "isPremiumOnly"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard with front and back content.",
      "type": "object",
      "properties": {
        "front": { "type": "string" },
        "back": { "type": "string" }
      },
      "required": ["front", "back"]
    },
    "Resource": {
      "title": "External Resource",
      "description": "A link to an external resource like a PDF on Google Drive or a YouTube video.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string", "enum": ["Notes", "Past Papers", "Videos"] },
        "isPremium": { "type": "boolean" },
        "viewCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "url", "category", "isPremium", "createdAt"]
    },
    "Video": {
      "title": "Educational Video",
      "description": "A YouTube video for learning.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "videoUrl": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "isPremiumOnly": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "subject", "topic", "videoUrl", "isPremiumOnly", "createdAt"]
    },
    "Post": {
      "title": "Community Post",
      "description": "A post shared by a user in the community.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "likes": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "authorName", "content", "likes", "commentsCount", "createdAt"]
    }
  },
  "firestore": {
    "/referrals/{referralId}": {
      "schema": { "$ref": "#/entities/Referral" },
      "description": "Tracks referrals."
    },
    "/resources/{resourceId}": {
      "schema": { "$ref": "#/entities/Resource" },
      "description": "Stores links to external resources."
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "#/entities/Video" },
      "description": "Stores educational videos."
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores community posts."
    },
    "/userStats/{userId}": {
      "schema": { "$ref": "#/entities/UserStats" },
      "description": "Stores user points and streaks."
    },
    "/syllabusProgress/{progressId}": {
      "schema": { "$ref": "#/entities/SyllabusProgress" },
      "description": "Stores user progress on syllabus."
    },
    "/papers/{paperId}": {
      "schema": { "$ref": "#/entities/Paper" },
      "description": "Stores past papers metadata."
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "Stores quizzes metadata."
    },
    "/quizzes/{quizId}/questions/{questionId}": {
      "schema": { "$ref": "#/entities/Question" },
      "description": "Stores quiz questions."
    },
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Stores study notes."
    },
    "/flashcardSets/{setId}": {
      "schema": { "$ref": "#/entities/FlashcardSet" },
      "description": "Stores flashcard sets metadata."
    },
    "/flashcardSets/{setId}/cards/{cardId}": {
      "schema": { "$ref": "#/entities/Flashcard" },
      "description": "Stores individual flashcards."
    }
  }
}
