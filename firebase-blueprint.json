{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Educate MW app.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "phoneNumber": {
          "type": "string",
          "description": "The user's phone number."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile photo URL."
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has an active premium subscription."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The ISO 8601 timestamp when the user was created."
        }
      },
      "required": ["uid", "displayName", "isPremium", "createdAt"]
    },
    "Paper": {
      "title": "Past Paper",
      "description": "A past examination paper.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "year": { "type": "string" },
        "level": { "type": "string" },
        "size": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "isPremiumOnly": { "type": "boolean" }
      },
      "required": ["subject", "year", "level", "size", "downloadUrl", "isPremiumOnly"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "A quiz challenge.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "questionsCount": { "type": "number" },
        "timeLimit": { "type": "string" },
        "color": { "type": "string" },
        "isPremiumOnly": { "type": "boolean" }
      },
      "required": ["subject", "topic", "questionsCount", "timeLimit", "color", "isPremiumOnly"]
    },
    "Note": {
      "title": "Study Note",
      "description": "A study note for a specific subject.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "content": { "type": "string" },
        "isPremiumOnly": { "type": "boolean" }
      },
      "required": ["subject", "topic", "content", "isPremiumOnly"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/papers/{paperId}": {
      "schema": { "$ref": "#/entities/Paper" },
      "description": "Stores past papers metadata."
    },
    "/quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/Quiz" },
      "description": "Stores quizzes metadata."
    },
    "/notes/{noteId}": {
      "schema": { "$ref": "#/entities/Note" },
      "description": "Stores study notes."
    }
  }
}
